# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Kaggle API credentials (place in ~/.kaggle/kaggle.json instead of here)
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key

# Competition settings
COMPETITION_NAME=orbit-wars
MAX_DAILY_SUBMISSIONS=5

# Local evaluation
LOCAL_TOURNAMENT_EPISODES=100
LOCAL_TOURNAMENT_SEED=42

# Experiment tracking
EXPERIMENT_BASE_DIR=experiments/results
LOG_DIR=logs/local
